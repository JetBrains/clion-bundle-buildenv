# Do not edit PKGBUILD directly — it is generated from PKGBUILD.template by
# scripts/sync-mingw-packages.sh using upstream.conf. Edit the template or conf instead.
pkgname=binutils
pkgver=2.46
pkgrel=1
pkgdesc="A set of programs to assemble and manipulate binary and object files (mingw-w64)"
arch=(x86_64)
url="https://www.gnu.org/software/binutils/"
license=('GPL')
makedepends=(libiconv zlib)
options=('staticlibs' 'strip')
_sourcedir=binutils-with-gold-${pkgver}

source=(
  https://ftp.gnu.org/gnu/binutils/binutils-with-gold-2.46.tar.bz2
  0002-check-for-unusual-file-harder.patch
  0010-bfd-Increase-_bfd_coff_max_nscns-to-65279.patch
  0011-libiberty-Preserve-errno-across-calls-to-libiberty_v.patch
  2001-ld-option-to-move-default-bases-under-4GB.patch
  2003-Revert-Restore-old-behaviour-of-windres-so-that-opti.patch
  reproducible-import-libraries.patch
  libiberty-unlink-handle-windows-nul.patch
  4000-fix-DEBUG_S_INLINEELINES.patch
)

sha256sums=(
  b8c9a3d796dc0b0e8ea935dc24c5c8d6f345eb177ada5ac6a5b1122c77d62158
  2c99345fc575c3a060d6677537f636c6c4154fac0fde508070f3b6296c1060d4
  4e8ac055df61b1b5d6ae29dc87e1154737c2e87c7b244b44866702cabf1a5d18
  90890cf76f820e61d4eeeef356b0d08ff0c7a90a07691b42a37a1e17abc29cda
  9945635f4a67712616202f09cbb66cf70df01be168c2c8054c455bb58bf334dd
  3e3c53b0751a6389cd50dcbd7f78b52aaa55113414da01d3415592af18809702
  a094660ec95996c00b598429843b7869037732146442af567ada9f539bd40480
  7ccbd418695733c50966068fa9755a6abb156f53af23701d2bc097c63e9e0030
  5ed35a728b956ad49a5e196ae59f681666f2754f0a4903b9280a430d7a312ea8
)

prepare() {
  cd "${srcdir}/${_sourcedir}"
  apply_patches
}

build() {
  [[ -d "${srcdir}/build-${CHOST}" ]] && rm -rf "${srcdir}/build-${CHOST}"
  mkdir -p "${srcdir}/build-${CHOST}"
  cd "${srcdir}/build-${CHOST}"

  ../${_sourcedir}/configure \
    --host=${CHOST} \
    --build=${MACHTYPE} \
    --target=${CHOST} \
    --prefix=${PREFIX} \
    --with-libiconv-prefix=${PREFIX}/${CHOST} \
    --enable-static \
    --enable-64-bit-bfd \
    --enable-install-libiberty \
    --enable-deterministic-archives \
    --disable-gold \
    --disable-lto \
    --disable-nls \
    --disable-rpath \
    --disable-shared \
    --disable-multilib

  make VERBOSE=1
}

check() {
  cd "${srcdir}/build-${CHOST}"
  make check
}

package() {
  cd "${srcdir}/build-${CHOST}"
  make DESTDIR="${pkgdir}" install-strip
  install_copying
}
