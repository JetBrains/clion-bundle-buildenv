# Do not edit PKGBUILD directly — it is generated from PKGBUILD.template by
# scripts/sync-mingw-packages.sh using upstream.conf. Edit the template or conf instead.
pkgname=(gmp)
pkgver=6.3.0
pkgrel=1
pkgdesc="A free library for arbitrary precision arithmetic"
arch=(aarch64 x86_64)
url="https://gmplib.org/"
license=(LGPL3 GPL)

source=(https://ftp.gnu.org/gnu/gmp/gmp-6.3.0.tar.xz)
sha256sums=(a3c2b80201b89e68616f4ad30bc66aee4927c3ce50e33929ca819d5c43538898)

options=('staticlibs' 'strip')

build() {
  [[ -d "${srcdir}/build-${CHOST}" ]] && rm -rf "${srcdir}/build-${CHOST}"
  mkdir -p "${srcdir}/build-${CHOST}"
  cd "${srcdir}/build-${CHOST}"

  ../${pkgname}-${pkgver}/configure \
    --prefix=${PREFIX} \
    --host=${CHOST} \
    --enable-static \
    --disable-shared

  make
}

package_gmp() {
  cd "${srcdir}/build-${CHOST}"
  make DESTDIR="${pkgdir}" install
}
