# Do not edit PKGBUILD directly — it is generated from PKGBUILD.template by
# scripts/sync-mingw-packages.sh using upstream.conf. Edit the template or conf instead.
pkgname=winpthreads
pkgver=13.0.0.r380.gb83511db8
pkgrel=1
pkgdesc="MinGW-w64 winpthreads"
arch=(x86_64)
url='https://mingw-w64.sourceforge.io/'
license=('MIT' 'BSD')
options=('strip' 'staticlibs' '!emptydirs')
depends=(crt)

source=(
  mingw-w64::git+https://github.com/mingw-w64/mingw-w64.git#commit=b83511db874df671190261d10d531cd9c0329cb3
  0001-Define-__-de-register_frame_info-in-fake-libgcc_s.patch
)

sha256sums=(
  SKIP
  2e779bcc60a1422b23e0cfdb5c0f6851f2382592bb4675d08a6bdef78d5e5c10
)

prepare() {
  cd "${srcdir}/mingw-w64"
  apply_patches

  cd "${srcdir}/mingw-w64/mingw-w64-libraries/${pkgname}"
  autoreconf -vfi
}

build() {
  [[ -d "${srcdir}/build-${CHOST}" ]] && rm -rf "${srcdir}/build-${CHOST}"
  mkdir -p "${srcdir}/build-${CHOST}"
  cd "${srcdir}/build-${CHOST}"

  ../mingw-w64/mingw-w64-libraries/${pkgname}/configure \
    --host=${CHOST} \
    --target=${CHOST} \
    --build=${MACHTYPE} \
    --prefix=${PREFIX} \
    --enable-static \
    --enable-shared \
    "CPPFLAGS=${CPPFLAGS//-D__USE_MINGW_ANSI_STDIO=1/}"

  make VERBOSE=1
}

package() {
  cd "${srcdir}/build-${CHOST}"
  make DESTDIR=${pkgdir} install-strip
  make DESTDIR=${PREFIX}/sysroot install

  mkdir -p ${pkgdir}${PREFIX}/${CHOST}
  mv ${pkgdir}${PREFIX}/{include,lib} \
    ${pkgdir}${PREFIX}/${CHOST}

  install_copying
}
