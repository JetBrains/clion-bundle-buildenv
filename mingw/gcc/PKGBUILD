pkgver=15.2.0
pkgrel=1
pkgdesc="GCC for the MinGW-w64"
arch=(x86_64)
url="https://gcc.gnu.org"
license=(GPL)
makedepends=(mpc libiconv crt headers winpthreads manifest)

