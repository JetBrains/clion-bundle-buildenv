# Do not edit PKGBUILD directly — it is generated from PKGBUILD.template by
# scripts/sync-mingw-packages.sh using upstream.conf. Edit the template or conf instead.
pkgname=crt
pkgver=13.0.0.r380.gb83511db8
pkgrel=1
pkgdesc="MinGW-w64 CRT"
arch=(x86_64)
url='https://mingw-w64.sourceforge.io/'
license=('custom')
options=('!strip' 'staticlibs' '!buildflags' '!emptydirs')
depends=('headers')

source=(
  mingw-w64::git+https://github.com/mingw-w64/mingw-w64.git#commit=b83511db874df671190261d10d531cd9c0329cb3
)

sha256sums=(
  SKIP
)

build() {
  [[ -d "${srcdir}/build-${CHOST}" ]] && rm -rf "${srcdir}/build-${CHOST}"
  mkdir -p "${srcdir}/build-${CHOST}"
  cd "${srcdir}/build-${CHOST}"

  ../mingw-w64/mingw-w64-crt/configure \
    --host=${CHOST} \
    --build=${MACHTYPE} \
    --prefix=${PREFIX}/${CHOST} \
    --enable-wildcard \
    --disable-dependency-tracking \
    --disable-lib32 \
    --enable-lib64 \
    --with-default-msvcrt=msvcrt \
    CFLAGS="-Wno-expansion-to-defined"

  make VERBOSE=1
}

package() {
  cd "${srcdir}/build-${CHOST}"
  make DESTDIR=${pkgdir} install
  make DESTDIR=${PREFIX}/sysroot install
  install_copying
}
