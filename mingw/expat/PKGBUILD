# Do not edit PKGBUILD directly — it is generated from PKGBUILD.template by
# scripts/sync-mingw-packages.sh using upstream.conf. Edit the template or conf instead.
pkgname=expat
pkgver=2.7.3
pkgrel=1
pkgdesc="An XML parser library (mingw-w64)"
arch=(aarch64 i686 x86_64)
url="https://libexpat.github.io/"
license=(MIT)
options=('strip' 'staticlibs')

source=(https://github.com/libexpat/libexpat/releases/download/R_2_7_3/expat-2.7.3.tar.xz
        )
sha256sums=(71df8f40706a7bb0a80a5367079ea75d91da4f8c65c58ec59bcdfbf7decdab9f
            )

prepare() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  apply_patches
}

build() {
  [[ -d "${srcdir}/build-${CHOST}" ]] && rm -rf "${srcdir}/build-${CHOST}"
  mkdir -p "${srcdir}/build-${CHOST}"
  cd "${srcdir}/build-${CHOST}"

  ../${pkgname}-${pkgver}/configure \
    --prefix=${PREFIX} \
    --host=${CHOST} \
    --target=${CHOST} \
    --disable-shared \
    --enable-static

  make
}

package() {
  cd "${srcdir}/build-${CHOST}"
  make DESTDIR="${pkgdir}" install
  install -Dm644 "${srcdir}/${pkgname}-${pkgver}/COPYING" "${pkgdir}${PREFIX}/share/licenses/${pkgname}/COPYING"
}
