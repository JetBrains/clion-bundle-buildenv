# Do not edit PKGBUILD directly — it is generated from PKGBUILD.template by
# scripts/sync-mingw-packages.sh using upstream.conf. Edit the template or conf instead.
pkgname=mpc
pkgver=1.3.1
pkgrel=1
pkgdesc="Multiple precision complex arithmetic library (mingw-w64)"
url='http://www.multiprecision.org'
license=('LGPL')
arch=(x86_64)
makedepends=(gmp mpfr)
options=('strip' 'staticlibs' '!emptydirs')

source=(
  https://ftp.gnu.org/gnu/mpc/mpc-1.3.1.tar.gz
)

sha256sums=(
  ab642492f5cf882b74aa0cb730cd410a81edcdbec895183ce930e706c1c759b8
)

build() {
  [[ -d "${srcdir}/build-${CHOST}" ]] && rm -rf "${srcdir}/build-${CHOST}"
  mkdir -p "${srcdir}/build-${CHOST}"
  cd "${srcdir}/build-${CHOST}"

  ../${pkgname}-${pkgver}/configure \
    --host=${CHOST} \
    --target=${CHOST} \
    --build=${MACHTYPE} \
    --prefix=${PREFIX} \
    --enable-static \
    --disable-shared \
    --with-gmp=${PREFIX} \
    --with-mpfr=${PREFIX}

  make VERBOSE=1
}

check() {
  cd "${srcdir}/build-${CHOST}"
  make check
}

package() {
  cd "${srcdir}/build-${CHOST}"
  make DESTDIR="${pkgdir}" install
  install_copying
}
